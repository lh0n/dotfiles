root = true

# Defaults for everything
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Makefiles require hard tabs — no choice here
[Makefile]
indent_style = tab

# Markdown: preserve trailing spaces (they mean <br>)
[*.md]
trim_trailing_whitespace = false
