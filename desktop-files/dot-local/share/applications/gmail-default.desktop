[Desktop Entry]
Version=1.0
Type=Application
Name=Gmail
Comment=Launch Gmail as a Chrome App
Exec=google-chrome "--profile-directory=Default" "--app=https://mail.google.com"
Icon=mail-gmail
Terminal=false
Categories=Network;Email;
StartupNotify=true
StartupWMClass=mail.google.com
MimeType=text/html;text/xml;application/xhtml+xml;
